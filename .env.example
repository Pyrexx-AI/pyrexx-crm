# ==========================================
# SUPABASE CONFIGURATION
# ==========================================
# Found in Supabase Dashboard -> Project Settings -> API

# The REST URL for your Supabase project (Used by both Client and Server)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# The safe, anonymous API key (Used by the frontend browser client)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# The secret service role key (Used ONLY on the server in API routes to bypass RLS securely)
# WARNING: Never prefix this with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"


# ==========================================
# EMAIL INFRASTRUCTURE (PHASE 2 & 5)
# ==========================================
# Found in Resend Dashboard -> API Keys

# The API key used by our EmailProvider adapter to dispatch outbound mail
# WARNING: Never prefix this with NEXT_PUBLIC_
RESEND_API_KEY="re_your_resend_api_key"


# ==========================================
# FUTURE PHASES (PLACEHOLDERS)
# ==========================================
# These will be required as we move into Phase 3 (Call Proxy) and Phase 7 (Billing)

# RETELL_API_KEY="your-retell-ai-api-key"
# DODO_PAYMENTS_SECRET="your-dodo-payments-key"